          "status": {
            "type": "string",
            "description": "Current status of the download",
            "enum": ["queued", "in_progress", "completed", "cancelled"]
          },
          "num_records": {
            "type": "integer",
            "description": "Number of records in the download"
          },
          "results": {
            "type": "array",
            "description": "Array of download result file links",
            "items": {
              "type": "object",
              "properties": {
                "url": {
                  "type": "string",
                  "description": "URL to download the result file"
                }
              }
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the download was created"
          }
        }
      },
      "ViewRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name for the view"
          },
          "fields": {
            "type": "array",
            "description": "List of fields to include in the view",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "View": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "View name"
          },
          "fields": {
            "type": "array",
            "description": "Fields included in this view",
            "items": {
              "type": "string"
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the view was created"
          }
        }
      },
      "RealTimeRequest": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Query for the real-time data request"
          },
          "num_records": {
            "type": "integer",
            "description": "Number of records to scrape in real-time"
          }
        }
      },
      "RealTimeUpdateRequest": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Query to identify records for real-time update"
          },
          "num_records": {
            "type": "integer",
            "description": "Number of records to update"
          }
        }
      },
      "AuthRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "Your Datafiniti account email"
          },
          "password": {
            "type": "string",
            "description": "Your Datafiniti account password"
          }
        }
      },
